# ---- Riot API ----
# Get your key at https://developer.riotgames.com
# Personal keys expire every 24 hours; production keys require approval
RIOT_API_KEY=RGAPI-your-key-here

# ---- Database ----
# PostgreSQL connection string
DATABASE_URL=postgres://riftmeta:riftmeta_secret@localhost:5432/riftmeta?sslmode=disable

# Docker Compose sets the password separately
POSTGRES_PASSWORD=riftmeta_secret

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Riot Region Settings ----
# Platform routing: na1, euw1, kr, br1, la1, la2, oc1, jp1, tr1, ru, ph2, sg2, th2, tw2, vn2
DEFAULT_REGION=na1

# Regional routing: americas, europe, asia, sea
DEFAULT_ROUTING=americas

# ---- Server ----
PORT=8080
